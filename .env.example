# Environment variables for NutritionTrackerPro
# Copy this file to .env and fill in your actual values

# MongoDB connection URI
# Option 1: MongoDB Atlas (cloud)
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# Go to Clusters → Your Cluster → Connect → Connect your application
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=YourAppName

# Option 2: Local MongoDB (recommended for development)
MONGODB_URI=your_mongodb_uri_here